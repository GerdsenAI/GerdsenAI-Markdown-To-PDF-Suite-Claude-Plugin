#!/usr/bin/env bash
# SessionStart hook: check if Document Builder is installed and report status
# Silent when not configured (users discover the plugin through commands)
# Warns only on broken installs or stale sources

# Load shared library — exit silently if plugin root was moved or library is missing
SCRIPT_DIR="$(dirname "$0")"
if ! source "$SCRIPT_DIR/../scripts/lib/parse-settings.sh" 2>/dev/null; then
  exit 0
fi
detect_platform

SETTINGS_FILE=".claude/gerdsenai.local.md"

# Quick check: does the settings file exist?
# If not, exit silently — users discover the plugin through commands, not unsolicited alerts
if [[ ! -f "$SETTINGS_FILE" ]]; then
  exit 0
fi

# Parse settings using shared library
parse_settings "$SETTINGS_FILE"
DOC_BUILDER_PATH="$GERDSEN_DOC_BUILDER_PATH"
OUTPUT_MODE="$GERDSEN_OUTPUT_MODE"

# Check builder path is valid
if [[ -z "$DOC_BUILDER_PATH" ]] || [[ ! -f "$DOC_BUILDER_PATH/document_builder_reportlab.py" ]]; then
  echo "GerdsenAI Document Builder installation appears broken. Run /gerdsenai:setup to fix it."
  exit 0
fi

# Check venv exists
if [[ ! -f "$DOC_BUILDER_PATH/$VENV_PYTHON_REL" ]]; then
  echo "GerdsenAI Document Builder venv is missing. Run /gerdsenai:setup to fix it."
  exit 0
fi

# Check for incomplete configuration (missing key v0.2 settings)
if [[ -z "$OUTPUT_MODE" ]]; then
  echo "GerdsenAI Document Builder is installed but not fully configured (missing output preferences). Run /gerdsenai:setup (choose \"Configure settings\") to complete setup."
  exit 0
fi

# Check for monitored reports with stale sources
PLUGIN_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
SOURCE_TRACKER="$PLUGIN_ROOT/scripts/source-tracker.py"

if [[ -f "$SOURCE_TRACKER" ]]; then
  # Find .sources.json files in the current directory tree (limit depth to avoid scanning huge trees)
  stale_output=""
  while IFS= read -r -d '' manifest; do
    # Quick check: does the manifest contain "changed" status?
    if grep -q '"status": "changed"' "$manifest" 2>/dev/null; then
      report_name="$(basename "${manifest%.sources.json}").md"
      stale_output="${stale_output}  - ${report_name}\n"
    fi
  done < <(find . -maxdepth 3 -name "*.sources.json" -print0 2>/dev/null)

  if [[ -n "$stale_output" ]]; then
    echo "Monitored reports with stale sources detected:"
    echo -e "$stale_output"
    echo "Run /gerdsenai:research-report <file> to review and update."
  fi
fi

# --- Vector DB health check (only if configured and hook enabled) ---
VENV_PY="$DOC_BUILDER_PATH/$VENV_PYTHON_REL"

if [[ -n "$GERDSEN_VECTOR_DB_MODE" ]] && [[ "$GERDSEN_VECTOR_DB_MODE" != "none" ]] && [[ "$GERDSEN_VECTOR_DB_HOOK_ON_SESSION_START" != "false" ]]; then
  vdb_status=""
  vdb_ok=false

  # Check ChromaDB availability (if mode includes it)
  if [[ "$GERDSEN_VECTOR_DB_MODE" == "chromadb" ]] || [[ "$GERDSEN_VECTOR_DB_MODE" == "dual" ]]; then
    if "$VENV_PY" -c "import chromadb" 2>/dev/null; then
      vdb_status="ChromaDB available"
      vdb_ok=true
    else
      # Auto-repair: reinstall ChromaDB silently in background (with lock)
      install_chromadb_locked "$VENV_PY" --background
      vdb_status="ChromaDB missing — auto-repair started (installing in background)"
    fi
  fi

  # Check Pinecone availability (if mode includes it)
  if [[ "$GERDSEN_VECTOR_DB_MODE" == "pinecone" ]] || [[ "$GERDSEN_VECTOR_DB_MODE" == "dual" ]]; then
    if [[ -n "${PINECONE_API_KEY:-}" ]]; then
      if [[ -n "$vdb_status" ]]; then
        vdb_status="${vdb_status}, Pinecone configured"
      else
        vdb_status="Pinecone configured"
      fi
      vdb_ok=true
    else
      if [[ -n "$vdb_status" ]]; then
        vdb_status="${vdb_status}, Pinecone API key not set"
      else
        vdb_status="Pinecone API key not set"
      fi
    fi
  fi

  if $vdb_ok; then
    echo "Vector DB: ${vdb_status}"
  else
    echo "Vector DB configured but no backends available. Run /gerdsenai:vector-db configure to fix."
  fi
fi

# Installed and fully configured - stay silent
exit 0
